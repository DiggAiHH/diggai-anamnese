# Copy this file to .env.n8n_local and edit values
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin
N8N_HOST=0.0.0.0
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678/

# Optional: override DB location (SQLite default if unset)
# N8N_DB_SQLITE_DATABASE=./n8n-data/database.sqlite
