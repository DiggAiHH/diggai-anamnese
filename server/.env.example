# Anamnese App - Production Environment Configuration
# BSI TR-03161 & DSGVO Compliance Requirement:
# DO NOT COMMUNICATE THIS FILE WITH ACTUAL SECRETS.
# Rename a copy of this file to `.env` and fill in the values below.

# ---------------------------------------------
# 1. Server Configuration
# ---------------------------------------------
PORT=3001
NODE_ENV=production

# ---------------------------------------------
# 2. Database (Encryption & Connections)
# ---------------------------------------------
# The PostgreSQL connection string
DATABASE_URL="postgresql://username:secure_password@localhost:5432/anamnese_db"

# AES-256-GCM Encryption Key (Must be EXACTLY 32 bytes/characters long)
# Used to encrypt patient PII in Database. DO NOT LOSE THIS KEY.
ENCRYPTION_KEY="replace-this-with-a-32-char-key!"

# ---------------------------------------------
# 3. Security tokens
# ---------------------------------------------
# JWT secret used for signing Arzt/MFA API tokens
JWT_SECRET="replace_with_a_highly_secure_long_random_string"

# ---------------------------------------------
# 4. Access Control
# ---------------------------------------------
# The default initial password for the 'admin' / 'arzt' account when seeding the database
ARZT_PASSWORD="change-me"

# ---------------------------------------------
# 5. Application Links
# ---------------------------------------------
# Allowed CORS Origin and API response routing
FRONTEND_URL="https://your-production-app.domain.tdl"

# ---------------------------------------------
# 6. Data Lifecycle (DSGVO)
# ---------------------------------------------
# Automatically delete patient sessions older than X days
RETENTION_DAYS=90

# ---------------------------------------------
# 7. Feature Flags (Modul 7/8)
# ---------------------------------------------
# Set to true to activate the respective module
NFC_ENABLED=false
PAYMENT_ENABLED=false
TELEMED_ENABLED=false

# ---------------------------------------------
# 8. Modul 5: Patienten-PWA
# ---------------------------------------------
# E-Mail SMTP (Account-Verifizierung, Passwort-Reset)
SMTP_HOST=smtp.your-domain.de
SMTP_PORT=587
SMTP_USER=noreply@your-domain.de
SMTP_PASS=change-me-smtp-password
SMTP_FROM="DiggAI <noreply@your-domain.de>"

# VAPID Keys für Web Push Notifications
# Generieren mit: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@your-domain.de

# ---------------------------------------------
# 9. Modul 6: Lokaler Modus / gematik / ePA
# ---------------------------------------------
DEPLOYMENT_MODE=CLOUD

# TI-Konnektor (nur LOCAL/HYBRID mode)
TI_ENABLED=false
TI_KONNEKTOR_URL=https://192.168.1.100:443
TI_MANDANT_ID=MandantId_1
TI_CLIENT_SYSTEM_ID=DiggAI_1
TI_WORKPLACE_ID=AP_1
TI_CLIENT_CERT_PATH=/certs/smcb.p12
TI_CLIENT_CERT_PASS=

# ePA
EPA_ENABLED=false

# KIM (Kommunikation im Medizinwesen)
KIM_ENABLED=false
KIM_FROM_ADDRESS=praxis@kim.telematik
KIM_SMTP_HOST=
KIM_SMTP_PORT=465
KIM_SMTP_USER=
KIM_SMTP_PASS=
KIM_POP3_HOST=
KIM_POP3_PORT=995
KIM_POP3_USER=
KIM_POP3_PASS=

# Backup (nur LOCAL mode)
LOCAL_BACKUP_ENCRYPTION_KEY=change-me-backup-encryption-key
BACKUP_SCHEDULE=0 2 * * *
