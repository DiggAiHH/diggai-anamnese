# ─── Database ───────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/anamnese_db"

# Tri-Backend Vorbereitung (optional): getrennte Datenbanken je Domäne
# Falls leer, wird auf DATABASE_URL zurückgefallen.
DATABASE_URL_PRACTICE="postgresql://user:password@localhost:5432/anamnese_practice"
DATABASE_URL_COMPANY="postgresql://user:password@localhost:5432/anamnese_company"
DATABASE_URL_AUTHORITY="postgresql://user:password@localhost:5432/anamnese_authority"

# Legacy-Aliases für bestehende Skripte
DATABASE_URL_BACKEND_1=""
DATABASE_URL_BACKEND_2=""
DATABASE_URL_BACKEND_3=""

# Backend-Profil: monolith | practice | company | authority
BACKEND_PROFILE="monolith"

# Aktiviert Route-Isolation nach Domäne (für 3 getrennte Backends)
ROUTE_DOMAIN_ISOLATION="false"

# Erzwingt strikte DB-Routing-Trennung (in monolith standardmäßig aus)
STRICT_DOMAIN_DB_ROUTING="false"

# ─── Server ─────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Security ───────────────────────────────────────
# JWT Secret – mindestens 32 Zeichen!
JWT_SECRET="CHANGE_ME_mindestens_32_zeichen_lang"
JWT_EXPIRES_IN="24h"

# AES-256 Encryption Key – genau 32 Zeichen!
# WICHTIG: Wert IMMER mit Anführungszeichen setzen, sonst wird ein
# rein-numerischer Wert (z. B. 12345678901234567890123456789012) in
# CI-/Docker-/YAML-Pipelines als Scientific-Notation eingelesen
# ("1.2345678901234568e+31") und der Server startet mit expliziter Fehlermeldung
# nicht. Empfehlung: Wert beginnt mit einem Buchstaben.
ENCRYPTION_KEY="CHANGE_ME_genau_32_zeichen_lang!"

# ─── Frontend ───────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
VITE_API_URL="http://localhost:3001/api"
API_PUBLIC_URL="http://localhost:3001/api"

# ─── Practice Branding (White-Label) ────────────────
# Override for per-practice deployments. Falls back to Klaproth defaults.
# Set these in Netlify Dashboard > Environment variables for each site.
VITE_PRACTICE_NAME="Praxis für Gefäßmedizin"
VITE_PRACTICE_DOCTOR="Dr. med. Christian Klaproth"
VITE_PRACTICE_SPECIALTY="Gefäßchirurgie · Venenheilkunde"
VITE_PRACTICE_ADDRESS="Musterstraße 42\n20095 Hamburg\n(Nähe Hauptbahnhof)"
VITE_PRACTICE_PHONE="Telefon: 040 / 123 456 78\nFax: 040 / 123 456 79"
VITE_PRACTICE_EMAIL="praxis@dr-klaproth.de"
# VITE_PRACTICE_LOGO_URL=""
# VITE_PRACTICE_WEBSITE_URL="https://www.praxis-fuer-gefaessmedizin.de"

# ─── Root Tenant Binding ────────────────────────────
# Explicit tenant identifier sent by the frontend for root (/) deployments.
# The backend maps "klaproth" to the canonical Klaproth tenant (BSNR 999999999).
# Only change this if the root practice changes.
VITE_TENANT_ID="klaproth"

# ─── Cookie Domain ──────────────────────────────────
# Required for cross-subdomain cookie sharing (e.g. diggai.de ↔ api.diggai.de).
# Set to ".diggai.de" in production. Leave empty for single-domain dev setups.
# COOKIE_DOMAIN=""

# ─── Netlify Deploy (CLI) ───────────────────────────
# Für non-interactive Deploys via scripts/deploy-guided.mjs.
# Production Site ID ist 4e24807c-6ea8-482e-8bef-6c688f7172bb (siehe netlify.toml).
# Token NIE committen — generiere unter Netlify Dashboard → User Settings → Applications.
NETLIFY_SITE_ID="4e24807c-6ea8-482e-8bef-6c688f7172bb"
NETLIFY_AUTH_TOKEN="CHANGE_ME_netlify_personal_access_token"

# ─── Default Arzt Credentials ──────────────────────
# Für seed.ts – BITTE ÄNDERN!
ARZT_PASSWORD="CHANGE_ME_starkes_passwort_mit_12_plus"

# ─── E2E Test Credentials (Playwright) ─────────────
# Passwörter können über ARZT_PASSWORD geerbt werden, wenn nicht separat gesetzt
E2E_ARZT_USERNAME="admin"
E2E_ARZT_PASSWORD=""
E2E_MFA_USERNAME="mfa"
E2E_MFA_PASSWORD=""

# ─── Feature Flags (Modul 7/8) ──────────────────────
NFC_ENABLED=false
PAYMENT_ENABLED=false
TELEMED_ENABLED=false
TI_ENABLED=false
EPA_ENABLED=false
KIM_ENABLED=false

# ─── Stripe Configuration ───────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...                # Backend only - NEVER expose to frontend
STRIPE_PUBLISHABLE_KEY=pk_test_...           # Used by frontend
STRIPE_WEBHOOK_SECRET=whsec_...              # Webhook endpoint secret

# Stripe Price IDs (create products in Stripe Dashboard first)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Frontend Stripe key (must match STRIPE_PUBLISHABLE_KEY)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Redis (optional, app degradiert auf In-Memory) ─
REDIS_URL="redis://localhost:6379"

# ─── LLM Provider ───────────────────────────────────
LLM_ENDPOINT="http://localhost:11434"
OPENAI_API_KEY=""

# ─── Email (nodemailer) ─────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Sichere Einmal-Links für Patienten-Downloads (Standard: 24h)
PACKAGE_LINK_TTL_HOURS="24"
PACKAGE_RSA_MODULUS_LENGTH="4096"

# ─── Push Notifications (VAPID) ─────────────────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ─── Agent System (Service 1) ───────────────────────
AGENT_CORE_URL="http://localhost:8000"

# ─── Logging ────────────────────────────────────────
LOG_LEVEL="debug"

# ─── Backup & Disaster Recovery ─────────────────────
# Backup-Verschlüsselung (genau 32 Zeichen oder länger)
BACKUP_ENCRYPTION_KEY="CHANGE_ME_genau_32_zeichen_lang!"

# Lokales Backup-Verzeichnis (optional)
BACKUP_DIR="./backups"

# AWS S3 für Offsite-Backups (optional)
AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
BACKUP_BUCKET="diggai-backups"

# Backup-Verhalten
BACKUP_CRON="0 3 * * *"           # Täglich um 03:00 Uhr
BACKUP_MONITOR_CRON="0 9 * * *"   # Health-Check täglich um 09:00
BACKUP_KEEP_LOCAL="false"         # Lokale Backups nach S3-Upload behalten?

# ─── Monitoring & Alerting ──────────────────────────
# Sentry Error Tracking (optional)
SENTRY_DSN=""
VITE_SENTRY_DSN=""
APP_VERSION="3.0.0"

# Grafana Dashboard
GRAFANA_USER="admin"
GRAFANA_PASSWORD="changeme"

# Alerting
SLACK_WEBHOOK_URL=""
PAGERDUTY_KEY=""
ALERT_EMAIL="admin@praxis.de"
