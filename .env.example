# ─── Database ───────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/anamnese_db"

# ─── Server ─────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Security ───────────────────────────────────────
# JWT Secret – mindestens 32 Zeichen!
JWT_SECRET="CHANGE_ME_mindestens_32_zeichen_lang"
JWT_EXPIRES_IN="24h"

# AES-256 Encryption Key – genau 32 Zeichen!
ENCRYPTION_KEY="CHANGE_ME_genau_32_zeichen_lang!"

# ─── Frontend ───────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
VITE_API_URL="http://localhost:3001/api"

# ─── Netlify Deploy (CLI) ───────────────────────────
# Für non-interactive Deploys via scripts/deploy-guided.mjs
NETLIFY_SITE_ID="d4c9bba2-71cc-48a1-81a4-14cb9ac5cb90"
NETLIFY_AUTH_TOKEN=""

# ─── Default Arzt Credentials ──────────────────────
# Für seed.ts – BITTE ÄNDERN!
ARZT_PASSWORD="CHANGE_ME_starkes_passwort_mit_12_plus"

# ─── Feature Flags (Modul 7/8) ──────────────────────
NFC_ENABLED=false
PAYMENT_ENABLED=false
TELEMED_ENABLED=false
TI_ENABLED=false
EPA_ENABLED=false
KIM_ENABLED=false

# ─── Redis (optional, app degradiert auf In-Memory) ─
REDIS_URL="redis://localhost:6379"

# ─── LLM Provider ───────────────────────────────────
LLM_ENDPOINT="http://localhost:11434"
OPENAI_API_KEY=""

# ─── Email (nodemailer) ─────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ─── Push Notifications (VAPID) ─────────────────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ─── Agent System (Service 1) ───────────────────────
AGENT_CORE_URL="http://localhost:8000"

# ─── Logging ────────────────────────────────────────
LOG_LEVEL="debug"
