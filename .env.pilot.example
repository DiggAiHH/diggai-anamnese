# DiggAI Anamnese – Pilot Environment (Supabase + Railway)
# Copy this file to .env.production and fill in all values marked CHANGE_ME
# These values also go into Railway Dashboard > Variables (backend)
# and Netlify Dashboard > Environment variables (frontend VITE_* vars only)

# ─── Database (Supabase) ──────────────────────────────────
# Get from: Supabase Dashboard > Project Settings > Database > URI
# Use the "Session pooler" connection string (port 5432) for persistent backends
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=production
BACKEND_PROFILE=monolith

# ─── Security ─────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CHANGE_ME_min_32_chars_random_hex_here"
JWT_EXPIRES_IN="24h"

# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex').slice(0,32))"
# Must be EXACTLY 32 characters
ENCRYPTION_KEY="CHANGE_ME_exactly_32_chars_here!"

# ─── URLs ─────────────────────────────────────────────────
# Frontend on Netlify (custom domain):
FRONTEND_URL="https://klaproth.diggai.de"

# Backend on Railway (get after first Railway deploy):
API_PUBLIC_URL="https://CHANGE_ME_YOUR_PROJECT.up.railway.app/api"

# Same for Vite build (set in Netlify Dashboard, not in .env):
VITE_API_URL="https://CHANGE_ME_YOUR_PROJECT.up.railway.app/api"

# ─── Seed Credentials ─────────────────────────────────────
# Used by prisma/seed.ts to create the initial Arzt + Admin user
ARZT_PASSWORD="CHANGE_ME_strong_password_12_plus"

# ─── E2E Test Credentials (Playwright) ────────────────────
E2E_ARZT_USERNAME="admin"
E2E_ARZT_PASSWORD="CHANGE_ME_same_as_ARZT_PASSWORD"
E2E_MFA_USERNAME="mfa"
E2E_MFA_PASSWORD="CHANGE_ME_same_as_ARZT_PASSWORD"

# ─── Feature Flags ────────────────────────────────────────
NFC_ENABLED=false
PAYMENT_ENABLED=false
TELEMED_ENABLED=false
TI_ENABLED=false
EPA_ENABLED=false
KIM_ENABLED=false

# ─── Redis (optional — falls back to in-memory) ───────────
# REDIS_URL="redis://localhost:6379"

# ─── Email (optional — falls back to no-op) ───────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── Push Notifications (optional) ───────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ─── LLM (optional) ───────────────────────────────────────
OPENAI_API_KEY=""

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL="info"

# ─── Backup (optional for pilot) ──────────────────────────
BACKUP_ENCRYPTION_KEY="CHANGE_ME_exactly_32_chars_here!"
BACKUP_DIR="./backups"

# ─── Monitoring (optional for pilot) ──────────────────────
SENTRY_DSN=""
VITE_SENTRY_DSN=""
APP_VERSION="3.0.0"
