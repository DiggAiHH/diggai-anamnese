              "raw": "{{baseUrl}}/arzt/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["arzt", "sessions"]
            },
            "description": "Get all patient sessions for doctor dashboard"
          }
        },
        {
          "name": "Get Session Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/arzt/sessions/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["arzt", "sessions", "{{sessionId}}"]
            },
            "description": "Get detailed session with decrypted PII"
          }
        },
        {
          "name": "Acknowledge Triage",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/arzt/triage/{{triageId}}/ack",
              "host": ["{{baseUrl}}"],
              "path": ["arzt", "triage", "{{triageId}}", "ack"]
            },
            "description": "Acknowledge a triage alert"
          }
        },
        {
          "name": "Update Session Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/arzt/sessions/{{sessionId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["arzt", "sessions", "{{sessionId}}", "status"]
            },
            "description": "Change session status (ACTIVE, COMPLETED, SUBMITTED, EXPIRED)"
          }
        },
        {
          "name": "Get AI Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/arzt/sessions/{{sessionId}}/summary",
              "host": ["{{baseUrl}}"],
              "path": ["arzt", "sessions", "{{sessionId}}", "summary"]
            },
            "description": "Get AI-generated session summary"
          }
        }
      ]
    },
