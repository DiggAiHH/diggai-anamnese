    {
      "name": "Atoms (Questions)",
      "item": [
        {
          "name": "List Atoms",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/atoms?module=basis",
              "host": ["{{baseUrl}}"],
              "path": ["atoms"],
              "query": [
                {
                  "key": "module",
                  "value": "basis"
                }
              ]
            },
            "description": "Get question atoms, optionally filtered"
          }
        },
        {
          "name": "Get Single Atom",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/atoms/0000",
              "host": ["{{baseUrl}}"],
              "path": ["atoms", "0000"]
            },
            "description": "Get single atom by ID"
          }
        },
        {
          "name": "Reorder Atoms",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orders\": [\n    { \"id\": \"0000\", \"orderIndex\": 0 },\n    { \"id\": \"0001\", \"orderIndex\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/atoms/reorder",
              "host": ["{{baseUrl}}"],
              "path": ["atoms", "reorder"]
            },
            "description": "Reorder atoms (drag & drop)"
          }
        },
