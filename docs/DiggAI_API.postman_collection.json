{
  "info": {
    "name": "DiggAI API v3.0.0",
    "description": "DiggAI Anamnese Platform API Collection\n\nBase URLs:\n- Production: https://api.diggai.de/api\n- Staging: https://api-staging.diggai.de/api\n\nAuthentication:\n- HttpOnly Cookie: token=<jwt>\n- Bearer Token: Authorization: Bearer <jwt>\n\nDocumentation: https://docs.diggai.de",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "3.0.0"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login (Arzt/MFA/Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"dr.klaproth\",\n  \"password\": \"your-secure-password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/arzt/login",
              "host": ["{{baseUrl}}"],
              "path": ["arzt", "login"]
            },
            "description": "Authenticate as medical staff. Sets HttpOnly cookie automatically."
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"dr.klaproth\",\n  \"password\": \"secure-password\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/arzt/login"
                }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"user\": {\n    \"id\": \"cluabcdefghijklmnop\",\n    \"username\": \"dr.klaproth\",\n    \"displayName\": \"Dr. Klapproth\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/arzt/logout",
              "host": ["{{baseUrl}}"],
              "path": ["arzt", "logout"]
            },
            "description": "Logout and invalidate current token"
          }
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Create Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"selectedService\": \"Termin / Anamnese\",\n  \"isNewPatient\": true,\n  \"gender\": \"W\",\n  \"birthDate\": \"1985-06-15\",\n  \"insuranceType\": \"Gesetzlich\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["sessions"]
            },
            "description": "Create a new patient session. Returns sessionId and JWT cookie."
          }
        },
        {
          "name": "Generate QR Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service\": \"Termin / Anamnese\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/qr-token",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "qr-token"]
            },
            "description": "Generate QR code token for patient self-start. Auth required."
          }
        },
        {
          "name": "Get Session State",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions/{{sessionId}}/state",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "{{sessionId}}", "state"]
            },
            "description": "Get full session state with answers and triage events"
          }
        },
        {
          "name": "Submit Session",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions/{{sessionId}}/submit",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "{{sessionId}}", "submit"]
            },
            "description": "Mark session as completed and submitted"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "refresh-token"]
            },
            "description": "Refresh expiring JWT token"
          }
        }
      ]
    },
    {
      "name": "Answers",
      "item": [
        {
          "name": "Submit Answer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"atomId\": \"0001\",\n  \"value\": \"Musterfrau\",\n  \"timeSpentMs\": 3500\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/{{sessionId}}/answers",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "{{sessionId}}", "answers"]
            },
            "description": "Submit an answer for a question. Triggers triage evaluation. Rate limited: 30/min."
          }
        }
      ]
    },
    {
      "name": "Arzt (Doctor)",
      "item": [
        {
          "name": "List Sessions",
          "request": {
            "method": "GET",
            "header": [],
