            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/atoms/0000/toggle",
              "host": ["{{baseUrl}}"],
              "path": ["atoms", "0000", "toggle"]
            },
            "description": "Activate/deactivate atom"
