{
  "name": "anamnese-app",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "build:analyze": "set ANALYZE=true && npm run build",
    "lint": "eslint .",
    "test": "vitest",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run src/",
    "test:unit:dashboard": "vitest run src/components/dashboards/ src/store/dashboardStore.test.ts",
    "test:unit:watch": "vitest src/",
    "test:server": "vitest run --config vitest.server.config.ts",
    "test:server:services": "vitest run --config vitest.server.config.ts server/services",
    "test:server:middleware": "vitest run --config vitest.server.config.ts server/middleware",
    "test:coverage": "vitest run --coverage",
    "test:coverage:dashboard": "vitest run --coverage src/components/dashboards/ src/store/dashboardStore.test.ts",
    "test:changed": "vitest run --changed",
    "test:related": "vitest related",
    "test:e2e": "npx playwright test",
    "test:e2e:dashboard": "npx playwright test e2e/dashboard.spec.ts",
    "test:e2e:dashboard:ui": "npx playwright test e2e/dashboard.spec.ts --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:remote": "node e2e/run-remote.mjs",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:load": "node scripts/run-load-tests.js",
    "test:load:api": "k6 run tests/load/api-load-test.js",
    "test:load:dashboard": "k6 run tests/load/dashboard-load-test.js",
    "test:load:websocket": "k6 run tests/load/websocket-load-test.js",
    "test:load:db": "k6 run tests/load/db-load-test.js",
    "test:lighthouse": "lhci autorun",
    "test:lighthouse:mobile": "lhci autorun --preset=mobile",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "security:scan": "node scripts/security-scan.js",
    "security:test": "vitest run --config vitest.security.config.ts",
    "security:all": "npm run security:audit && npm run security:test",
    "scorecard": "node scripts/quality-scorecard.cjs",
    "scorecard:fast": "node scripts/quality-scorecard.cjs --fast",
    "scorecard:baseline": "node scripts/quality-scorecard.cjs --baseline",
    "scorecard:compare": "node scripts/quality-scorecard.cjs --compare",
    "preview": "vite preview",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:full": "tsx prisma/seed-comprehensive.ts",
    "db:seed:demo": "tsx prisma/seed-demo.ts",
    "db:seed:demo:complete": "tsx prisma/seed-demo-complete.ts",
    "db:seed:test": "tsx prisma/seed-testdata.ts",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:deploy": "npx prisma migrate deploy",
    "db:reset:app-data": "tsx scripts/reset-app-data.ts",
    "db:reset:app-data:seed": "npm run db:reset:app-data && npm run db:seed",
    "backup:create": "tsx scripts/backup-database.ts",
    "backup:restore": "tsx scripts/restore-database.ts",
    "backup:status": "curl -s http://localhost:3001/api/system/backup-status | jq",
    "backup:ops": "bash scripts/backup-operations.sh",
    "backup:billing": "tsx scripts/backup-billing.ts",
    "backup:billing:dry": "tsx scripts/backup-billing.ts --dry-run",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "monitoring:up": "docker compose -f docker-compose.monitoring.yml up -d",
    "monitoring:down": "docker compose -f docker-compose.monitoring.yml down",
    "monitoring:logs": "docker compose -f docker-compose.monitoring.yml logs -f",
    "deploy": "node scripts/deploy-guided.mjs",
    "deploy:prod": "node scripts/deploy-guided.mjs",
    "deploy:preview": "node scripts/deploy-guided.mjs --preview",
    "mem:install:all": "node scripts/install-claude-mem-all.mjs",
    "mem:install:all:gemini": "set CMEM_PROVIDER=gemini&& node scripts/install-claude-mem-all.mjs",
    "mem:install:all:openrouter": "set CMEM_PROVIDER=openrouter&& node scripts/install-claude-mem-all.mjs",
    "type-check": "tsc -b tsconfig.app.json tsconfig.node.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "tokens:generate": "npx ts-node scripts/generate-tokens.ts",
    "tokens:watch": "npx chokidar src/tokens/tokens.json -c 'npm run tokens:generate'",
    "check-all": "npm run type-check && npm run lint && node scripts/generate-i18n.ts && npx prisma migrate status",
    "preflight": "node scripts/deploy-preflight.mjs",
    "export:product": "node scripts/export-product-functionality.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix"
    ],
    "public/locales/**/*.json": [
      "node -e \"JSON.parse(require('fs').readFileSync(process.argv[1]))\" --"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@faker-js/faker": "^10.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.2",
    "@sentry/node": "^10.45.0",
    "@sentry/react": "^10.45.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/dom": "^10.4.1",
    "@types/pdfkit": "^0.17.5",
    "amqplib": "^0.10.9",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "chokidar": "^4.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "html5-qrcode": "^2.3.8",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "ioredis": "^5.6.1",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.575.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-soap": "^1.0.0",
    "nodemailer": "^8.0.1",
    "ollama": "^0.5.18",
    "pdfkit": "^0.18.0",
    "prisma": "^6.19.2",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "rate-limit-redis": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "sanitize-html": "^2.17.1",
    "signature_pad": "^5.1.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^20.4.1",
    "tailwindcss": "^4.2.1",
    "tesseract.js": "^7.0.0",
    "vitest-mock-extended": "^3.1.0",
    "web-push": "^3.6.7",
    "web-vitals": "^5.1.0",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@netlify/functions": "^5.1.2",
    "@playwright/test": "^1.58.2",
    "@simplewebauthn/types": "^12.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/amqplib": "^0.10.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.14",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^15.5.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rollup-plugin-visualizer": "5.12.0",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "workbox-background-sync": "^7.4.0"
  },
  "overrides": {
    "vite": "^8.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "effect": "^3.21.0",
    "defu": "^6.1.7",
    "lodash": "^4.18.1",
    "path-to-regexp": "^8.4.2",
    "@rollup/pluginutils": {
      "picomatch": "2.3.2"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    }
  }
}
