{
  "name": "anamnese-app",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:full": "tsx prisma/seed-comprehensive.ts",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:deploy": "npx prisma migrate deploy",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "deploy": "node scripts/deploy-guided.mjs",
    "deploy:prod": "node scripts/deploy-guided.mjs",
    "deploy:preview": "node scripts/deploy-guided.mjs --preview"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
