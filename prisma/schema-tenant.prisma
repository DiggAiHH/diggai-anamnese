// Multi-Tenancy Schema Extension for DiggAI Anamnese Platform
// Merge this into schema.prisma for SaaS deployment

// ─── TENANT MASTER (Multi-Tenancy Core) ─────────────────────

enum TenantPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
  PENDING_SETUP
}

model Tenant {
  id          String       @id @default(uuid())
  subdomain   String       @unique // praxis-dr-mueller
  name        String       // Dr. Müller Praxis
  legalName   String?      // Rechtlicher Firmenname
  
  // Plan & Billing
  plan        TenantPlan   @default(STARTER)
  status      TenantStatus @default(ACTIVE)
  
  // White-Labeling
  primaryColor    String?  @default("#3b82f6")
  logoUrl         String?
  customDomain    String?  @unique
  welcomeMessage  String?
  
  // Contact Info (for invoices/legal)
  contactEmail    String?
  contactPhone    String?
  contactAddress  String?
  taxId           String?
  
  // Stripe Integration
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  subscriptionExpiresAt DateTime?
  
  // Limits (enforced in application layer)
  maxUsers            Int @default(5)
  maxPatientsPerMonth Int @default(1000)
  storageLimitMB      Int @default(1024) // 1GB default
  
  // Compliance
  dsgvoAgreementSigned    Boolean @default(false)
  dsgvoAgreementSignedAt  DateTime?
  dsgvoAgreementSignedBy  String?
  
  // Settings JSON for extensibility
  settings    Json?   @default("{}")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  users       ArztUser[]
  patients    Patient[]
  sessions    PatientSession[]
  auditLogs   AuditLog[]
  
  @@index([subdomain])
  @@index([status])
  @@index([customDomain])
  @@index([plan])
}

