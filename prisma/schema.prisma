// Anamnese App – Prisma Schema
// PostgreSQL für Produktion (Docker Compose mit VPS)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Patient (Pseudonymisiert) ──────────────────────────────

model Patient {
  id               String    @id @default(uuid())
  hashedEmail      String    @unique // SHA-256 für Wiedererkennung
  patientNumber    String?   @unique // Fortlaufende PID (z.B. "P-10001")
  insuranceNumHash String?   // SHA-256 der Versicherungsnummer
  birthDate        DateTime? // Für schnelle Wiedererkennung
  gender           String?   // M / W / D (gespeichert für Fast-Track)
  encryptedName    String?   // AES-256-GCM verschlüsselt
  securityPattern  String?   // bcrypt-Hash der Muster-Sequenz
  verifiedAt       DateTime? // MFA-Zertifizierung Zeitpunkt
  verifiedBy       String?   // ArztUser.id der MFA-Kraft
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  sessions         PatientSession[]
  medications      PatientMedication[]
  surgeries        PatientSurgery[]

  // Modul 3: PVS-Verknüpfung
  pvsLinks         PvsPatientLink[]
  versichertenNr   String?   // 10-stellig (KVNR)
  versichertenArt  String?   // "GKV" | "PKV" | "BG" | "SZ"
  kassennummer     String?   // IK-Nummer (9-stellig)
  kassenname       String?

  // Modul 4: Therapieplan & Alerts
  therapyPlans     TherapyPlan[]
  clinicalAlerts   ClinicalAlert[]
  anonId           AnonPatientId?

  // Modul 5: Patienten-Portal PWA
  account          PatientAccount?

  @@index([insuranceNumHash, birthDate])
}

// ─── Session (Eine Fragebogen-Sitzung) ──────────────────────

model PatientSession {
  id              String   @id @default(uuid())
  patientId       String?
  patient         Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)

  isNewPatient    Boolean?
  gender          String?       // M / W / D
  birthDate       DateTime?
  encryptedName   String?       // AES-256-GCM verschlüsselt
  status          String        @default("ACTIVE") // ACTIVE, COMPLETED, SUBMITTED, EXPIRED

  // Kontext
  selectedService String        // TERMIN, REZEPT, AU, UEBERWEISUNG, etc.
  insuranceType   String?       // PKV, GKV, Selbstzahler

  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  completedAt     DateTime?
  assignedArztId  String?
  assignedArzt    ArztUser? @relation("ArztAssignedSessions", fields: [assignedArztId], references: [id])

  // Beziehungen
  answers         Answer[]
  triageEvents    TriageEvent[]
  chatMessages    ChatMessage[]
  accidentDetails AccidentDetails?
  queueEntry      QueueEntry?

  // Modul 3: PVS-Export-Status
  pvsExported     Boolean   @default(false)
  pvsExportedAt   DateTime?
  pvsExportRef    String?   // Referenz-ID im PVS

  // Modul 4: Therapieplan & Alerts
  therapyPlans    TherapyPlan[]
  clinicalAlerts  ClinicalAlert[]

  @@index([patientId, createdAt])
  @@index([status])
}

// ─── Accident Details (BG-Daten) ────────────────────────────

model AccidentDetails {
  id                String         @id @default(uuid())
  sessionId         String         @unique
  session           PatientSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  bgName            String
  accidentDate      DateTime
  accidentLocation  String
  description       String         // Kann in Zukunft bei SQLite auch @db.Text sein, Prisma SQLite ignoriert das
  firstResponder    String?
  reportedToEmployer Boolean       @default(false)
  
  @@index([sessionId])
}

// ─── Antwort (Ein einzelner beantworteter Atom) ─────────────

model Answer {
  id             String         @id @default(uuid())
  sessionId      String
  session        PatientSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  atomId         String         // Frage-ID, z.B. "0000", "RES-100"
  value          String         // JSON string: { type: 'radio', data: 'ja' }
  encryptedValue String?        // AES-256-GCM für PII-Freitexte

  // UX Tracking
  timeSpentMs    Int            @default(0)
  answeredAt     DateTime       @default(now())

  @@unique([sessionId, atomId])
  @@index([sessionId])
}

// ─── Triage Event (Red Flag Auslöser) ───────────────────────

model TriageEvent {
  id             String         @id @default(uuid())
  sessionId      String
  session        PatientSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  level          String         // WARNING, CRITICAL
  atomId         String         // Auslösende Frage
  triggerValues  String         // JSON string
  message        String

  createdAt      DateTime       @default(now())
  acknowledgedBy String?        // Arzt-ID wenn bestätigt
  acknowledgedAt DateTime?

  @@index([sessionId])
  @@index([level, acknowledgedBy])
}

// ─── Fragen-Katalog (Master-Tabelle) ────────────────────────

model MedicalAtom {
  id              String   @id // z.B. "0000", "RES-100", "2080"
  module          Int      // Gruppierung (0=Basis, 1=Beschwerden, 2=Enrollment, etc.)
  category        Int      @default(0) // Unterkategorie
  questionText    String
  description     String?
  answerType      String   // text, number, select, multiselect, radio, date, time, email, tel, textarea
  section         String   // Logische Sektion (basis, beschwerden, rezepte, etc.)
  orderIndex      Int      // Sortierung
  placeholder     String?

  // Optionen als JSON string
  options         String?    // JSON: [{ value, label, followUpQuestions?, redFlagTrigger? }]
  validationRules String?    // JSON: { required, min, max, pattern, ageOver, etc. }
  branchingLogic  String?    // JSON: { next, conditional, showIf, triage }

  // Flags
  isRedFlag       Boolean  @default(false)
  isPII           Boolean  @default(false) // Markiert Felder die verschlüsselt werden müssen
  isActive        Boolean  @default(true)  // Frage aktiviert/deaktiviert (Admin)
  parentAtomId    String?  // Für hierarchische Follow-ups

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([module, orderIndex])
  @@index([section])
}

// ─── Arzt-Benutzer ──────────────────────────────────────────

model ArztUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   // bcrypt
  pinHash      String?  // bcrypt 4-digit PIN für Quick-Login (Kiosk)
  displayName  String
  role         String   @default("ARZT") // PATIENT, ARZT, MFA, ADMIN
  isActive     Boolean  @default(true)
  customPermissions String?  // JSON: string[] — Zusätzliche Permission-Codes über Rolle hinaus
  lastLoginAt       DateTime?
  loginCount        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  assignedSessions PatientSession[] @relation("ArztAssignedSessions")
  appointments     Appointment[]    @relation("ArztAppointments")

  // Modul 4: Therapieplan-Erstellung
  createdTherapyPlans TherapyPlan[] @relation("TherapyPlanCreator")
}

// ─── Audit Log (HIPAA Compliance) ───────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  // Wer hat die Aktion ausgeführt
  action    String   // CREATE_SESSION, ANSWER_QUESTION, VIEW_SESSION, etc.
  resource  String   // sessions/abc-123, answers/xyz-456
  ipAddress String?
  userAgent String?
  metadata  String?  // JSON string: Zusätzliche Kontextdaten
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// ─── Chat-Nachrichten (Kommunikations-Log) ──────────────────

model ChatMessage {
  id        String         @id @default(uuid())
  sessionId String
  session   PatientSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  senderType String        // PATIENT, ARZT, MFA
  senderId   String?       // Verweis auf ArztUser id, falls von Personal
  
  text      String
  fromName  String         // z.B. "Dr. Schmidt", "MFA Team", "Patient"
  timestamp DateTime       @default(now())

  @@index([sessionId, timestamp])
}

// ─── Patient Medication (Dauermedikation) ───────────────────

model PatientMedication {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  name        String   // z.B. "Ramipril"
  dosage      String   // z.B. "5mg"
  frequency   String   // z.B. "1-0-1"
  notes       String?  // Optionale Freitext-Notizen

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([patientId])
}

// ─── Patient Surgeries (OP-Historie) ─────────────────────────

model PatientSurgery {
  id            String   @id @default(uuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  surgeryName   String   // z.B. "Blinddarm-OP"
  date          String?  // z.B. "2015" oder "Juni 2022"
  complications String?
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([patientId])
}

// ─── Chat Analytics (Bot-Interaktionen) ─────────────────────

model ChatAnalytics {
  id            String   @id @default(uuid())
  sessionId     String?
  queryText     String
  matchedIntent String?
  confidence    Float    @default(0)
  wasEscalated  Boolean  @default(false)
  language      String   @default("de")
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([matchedIntent])
}

// ─── Appointment (Terminplanung) ────────────────────────────

model Appointment {
  id          String   @id @default(uuid())
  patientName String
  sessionId   String?
  arztId      String?
  arzt        ArztUser? @relation("ArztAppointments", fields: [arztId], references: [id])
  service     String
  date        DateTime
  duration    Int      @default(30) // Minuten
  status      String   @default("SCHEDULED") // SCHEDULED, CONFIRMED, CANCELLED, COMPLETED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([arztId])
}

// ─── Queue Entry (Persistente Warteschlange) ────────────────

model QueueEntry {
  id                  String   @id @default(uuid())
  sessionId           String   @unique
  patientName         String   // AES-verschlüsselt
  service             String
  priority            String   @default("NORMAL") // NORMAL, URGENT, EMERGENCY
  status              String   @default("WAITING") // WAITING, CALLED, IN_TREATMENT, DONE
  position            Int      @default(0)
  joinedAt            DateTime @default(now())
  calledAt            DateTime?
  treatmentStartedAt  DateTime?
  completedAt         DateTime?
  estimatedWaitMin    Int?
  entertainmentMode   String   @default("AUTO") // AUTO, GAMES, READING, QUIET
  contentHistory      String?  // JSON: string[] — IDs der bereits gesehenen Contents
  deviceType          String?  // TABLET, MOBILE, DESKTOP
  feedbackRating      Int?     // 1-5 Sterne nach Besuch

  session             PatientSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([status, priority])
  @@index([joinedAt])
}

// ─── Waiting Content (Wartezeit-Engagement Material) ────────

model WaitingContent {
  id                 String   @id @default(uuid())
  type               String   // HEALTH_TIP, PRAXIS_NEWS, MINI_QUIZ, BREATHING_EXERCISE, FUN_FACT, SEASONAL_INFO
  category           String   // "allgemein", "ernaehrung", "bewegung", "psyche", "saisonal", "praxis"
  title              String
  body               String   // Markdown-fähiger Inhalt
  imageUrl           String?  // Optional: Illustrationslink
  quizData           String?  // JSON: { question, options: [{text, correct}], explanation }
  priority           Int      @default(0)  // Höher = wird bevorzugt angezeigt
  isActive           Boolean  @default(true)
  seasonal           String?  // "SPRING", "SUMMER", "AUTUMN", "WINTER" oder null für ganzjährig
  language           String   @default("de") // ISO 639-1
  minWaitMin         Int      @default(0)    // Zeige erst ab X Minuten Wartezeit
  maxWaitMin         Int?     // Zeige nur bis X Minuten (null = unbegrenzt)
  displayDurationSec Int      @default(30) // Wie lange der Content angezeigt wird
  viewCount          Int      @default(0)
  likeCount          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([type, isActive, language])
  @@index([seasonal, isActive])
}

// ─── Waiting Analytics (Engagement-Tracking) ────────────────

model WaitingAnalytics {
  id                  String   @id @default(uuid())
  sessionId           String
  contentId           String?  // FK zu WaitingContent (nullable für Flow-Events)
  eventType           String   // CONTENT_VIEW, CONTENT_LIKE, QUIZ_ANSWER, GAME_START, GAME_COMPLETE, INFOBREAK_VIEW, INFOBREAK_SKIP
  metadata            String?  // JSON: { quizCorrect?, gameScore?, durationSec?, skippedAfterSec? }
  waitPositionAtEvent Int?     // Queue-Position als der Event stattfand
  createdAt           DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([contentId, eventType])
}

// ─── Permission (Rechte-System) ─────────────────────────────

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique  // z.B. "patients.view", "queue.manage", "admin.content"
  name        String   // Anzeigename: "Patienten ansehen"
  description String?  // "Zugriff auf Patientenliste und Detailansicht"
  category    String   // "patients", "queue", "admin", "export", "triage", "chat", "atoms"
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@index([category])
}

// ─── Role + Permission Zuordnung ────────────────────────────

model RolePermission {
  id           String     @id @default(uuid())
  role         String     // "ARZT", "MFA", "ADMIN" — oder custom role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedAt    DateTime   @default(now())
  grantedBy    String?    // userId des Admins

  @@unique([role, permissionId])
  @@index([role])
}

// ─── Wunschbox (Feature Requests) ───────────────────────────

model WunschboxEntry {
  id              String   @id @default(uuid())
  submittedBy     String   // userId
  originalText    String   // Freitext des Users
  aiParsedChanges String?  // JSON: [{ area, description, priority, estimatedEffort }]
  status          String   @default("PENDING") // PENDING, AI_PROCESSED, REVIEWED, APPROVED, REJECTED, IMPLEMENTED
  adminNotes      String?
  exportedSpec    String?  // JSON: Fertiges Spezifikations-Dokument
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reviewedAt      DateTime?
  reviewedBy      String?

  @@index([status, createdAt])
  @@index([submittedBy])
}

// ─── ROI Snapshot (Tagesbasierte Wirtschaftlichkeit) ────────

model ROISnapshot {
  id                    String   @id @default(uuid())
  date                  DateTime @default(now()) @unique
  patientsServed        Int
  sessionsCompleted     Int
  avgCompletionMinutes  Float
  messagesCount         Int
  mfaMinutesSaved       Float
  estimatedCostSaving   Float

  // Konfigurierbare Praxis-Parameter (bei Erstellung kopiert)
  mfaHourlyCost         Float    @default(22.50)
  avgManualIntakeMin    Float    @default(12.0)
  monthlyLicenseCost    Float    @default(299.0)

  @@index([date])
}

// ─── Atom Draft (Fragebogen-Entwürfe) ───────────────────────

model AtomDraft {
  id             String    @id @default(uuid())
  atomId         String?   // null = neuer Atom, sonst = Bearbeitung bestehender
  draftData      String    // JSON: Kompletter MedicalAtom als Draft
  status         String    @default("DRAFT") // DRAFT, PENDING_REVIEW, APPROVED, PUBLISHED, REJECTED
  createdBy      String    // userId
  reviewedBy     String?
  publishedAt    DateTime?
  changeNote     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([atomId])
}

// ─── Modul 3: PVS-Integration ───────────────────────────────

enum PvsType {
  CGM_M1
  MEDATIXX
  MEDISTAR
  T2MED
  X_ISYNET
  DOCTOLIB
  TURBOMED
  FHIR_GENERIC
}

enum PvsProtocol {
  GDT
  BDT
  FHIR
  REST
  KIM
}

enum TransferDirection {
  IMPORT
  EXPORT
  BIDIRECTIONAL
}

enum TransferStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
}

model PvsConnection {
  id              String      @id @default(uuid())
  praxisId        String      @unique
  pvsType         PvsType
  pvsVersion      String?
  protocol        PvsProtocol @default(GDT)

  // GDT-spezifisch
  gdtImportDir    String?
  gdtExportDir    String?
  gdtFilePattern  String?     @default("*.gdt")
  gdtEncoding     String?     @default("ISO-8859-15")
  gdtSenderId     String?     // 8-stellig
  gdtReceiverId   String?     // 8-stellig

  // FHIR-spezifisch
  fhirBaseUrl     String?
  fhirAuthType    String?     // "basic" | "oauth2" | "apikey"
  fhirCredentials String?     // AES-256-GCM verschlüsselt
  fhirTenantId    String?

  // KIM-spezifisch
  kimAddress      String?
  kimSmtpHost     String?
  kimSmtpPort     Int?

  // Connection-Status
  isActive        Boolean     @default(true)
  lastSyncAt      DateTime?
  lastError       String?
  syncIntervalSec Int         @default(30)
  retryCount      Int         @default(3)

  // Auto-Mapping
  autoMapFields   Boolean     @default(true)
  customMappings  Json?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  transferLogs    PvsTransferLog[]
  fieldMappings   PvsFieldMapping[]

  @@index([pvsType])
  @@index([isActive])
}

model PvsTransferLog {
  id              String          @id @default(uuid())
  connectionId    String
  connection      PvsConnection   @relation(fields: [connectionId], references: [id])

  direction       TransferDirection
  protocol        PvsProtocol
  status          TransferStatus  @default(PENDING)

  entityType      String          // "Patient" | "PatientSession" | "Answer"
  entityId        String

  satzart         String?         // GDT Satzart
  resourceType    String?         // FHIR Resource Type
  rawPayload      String?         // AES-256-GCM verschlüsselt
  transformedData Json?

  pvsReferenceId  String?
  errorMessage    String?
  errorCode       String?
  retryAttempt    Int             @default(0)
  maxRetries      Int             @default(3)

  startedAt       DateTime        @default(now())
  completedAt     DateTime?
  durationMs      Int?

  initiatedBy     String?         // ArztUser.id oder "system"
  createdAt       DateTime        @default(now())

  @@index([connectionId, status])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([status])
}

model PvsFieldMapping {
  id              String          @id @default(uuid())
  connectionId    String
  connection      PvsConnection   @relation(fields: [connectionId], references: [id])

  diggaiModel     String          // "Patient" | "Answer" | "PatientSession"
  diggaiField     String

  pvsFieldId      String          // GDT: Feldkennung | FHIR: FHIRPath
  pvsFieldName    String?

  direction       TransferDirection @default(BIDIRECTIONAL)
  transformRule   String?         // "direct" | "map:ja→1,nein→0" | "format:date:YYYYMMDD"
  defaultValue    String?
  isRequired      Boolean         @default(false)
  isActive        Boolean         @default(true)
  validationRule  String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([connectionId, diggaiModel, diggaiField, pvsFieldId])
  @@index([connectionId])
}

model PvsPatientLink {
  id              String      @id @default(uuid())
  patientId       String
  patient         Patient     @relation(fields: [patientId], references: [id])

  pvsType         PvsType
  pvsPatientId    String
  pvsPatientNr    String?

  lastSyncAt      DateTime?
  syncStatus      String      @default("linked") // linked | conflict | unlinked
  conflictData    Json?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([patientId, pvsType])
  @@unique([pvsType, pvsPatientId])
  @@index([pvsPatientId])
}

// ─── Modul 4: Therapieplan & Arzt-Assistenz ─────────────────

enum TherapyStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum MeasureStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  SKIPPED
  OVERDUE
}

enum MeasureType {
  MEDICATION
  PROCEDURE
  REFERRAL
  LAB_ORDER
  IMAGING
  LIFESTYLE
  FOLLOW_UP
  DOCUMENTATION
  CUSTOM
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
  EMERGENCY
}

enum AlertCategory {
  VITAL_SIGN
  DRUG_INTERACTION
  ALLERGY_CONFLICT
  TRIAGE_ESCALATION
  SYMPTOM_PATTERN
  AGE_RISK
  CUSTOM
}

model TherapyPlan {
  id              String          @id @default(uuid())
  sessionId       String
  session         PatientSession  @relation(fields: [sessionId], references: [id])
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id])
  createdById     String
  createdBy       ArztUser        @relation("TherapyPlanCreator", fields: [createdById], references: [id])

  title           String
  status          TherapyStatus   @default(DRAFT)
  diagnosis       String?
  icdCodes        String[]
  summary         String?

  aiGenerated     Boolean         @default(false)
  aiModel         String?
  aiConfidence    Float?
  aiPromptHash    String?

  startDate       DateTime        @default(now())
  targetEndDate   DateTime?
  actualEndDate   DateTime?

  lastReviewedAt  DateTime?
  lastReviewedBy  String?
  nextReviewDate  DateTime?

  pvsExported     Boolean         @default(false)
  pvsExportedAt   DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  measures        TherapyMeasure[]
  alerts          ClinicalAlert[]

  @@index([patientId])
  @@index([sessionId])
  @@index([status])
  @@index([createdById])
}

model TherapyMeasure {
  id              String          @id @default(uuid())
  planId          String
  plan            TherapyPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  type            MeasureType
  title           String
  description     String?
  status          MeasureStatus   @default(PLANNED)
  priority        Int             @default(0)

  medicationName  String?
  dosage          String?
  duration        String?
  pzn             String?
  atcCode         String?

  referralTo      String?
  referralReason  String?
  referralUrgency String?

  labParameters   String[]

  scheduledDate   DateTime?
  completedDate   DateTime?
  dueDate         DateTime?

  aiSuggested     Boolean         @default(false)
  aiConfidence    Float?
  arztApproved    Boolean         @default(false)
  arztModified    Boolean         @default(false)

  notes           String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([planId, priority])
  @@index([status])
}

model ClinicalAlert {
  id              String          @id @default(uuid())

  sessionId       String?
  session         PatientSession? @relation(fields: [sessionId], references: [id])
  planId          String?
  plan            TherapyPlan?    @relation(fields: [planId], references: [id])
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id])

  severity        AlertSeverity
  category        AlertCategory
  title           String
  message         String

  triggerField    String?
  triggerValue    String?
  triggerRule     String?

  isRead          Boolean         @default(false)
  readAt          DateTime?
  readBy          String?
  isDismissed     Boolean         @default(false)
  dismissedAt     DateTime?
  dismissedBy     String?
  dismissReason   String?

  actionTaken     String?
  actionTakenAt   DateTime?
  actionTakenBy   String?

  createdAt       DateTime        @default(now())

  @@index([patientId, severity])
  @@index([sessionId])
  @@index([isRead, severity])
  @@index([createdAt])
}

model TherapyTemplate {
  id              String          @id @default(uuid())

  name            String
  description     String?
  category        String
  icdCodes        String[]

  measures        Json
  defaultDuration String?

  isDefault       Boolean         @default(false)
  createdById     String?
  usageCount      Int             @default(0)
  isActive        Boolean         @default(true)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([category])
  @@index([isActive])
}

model AnonPatientId {
  id              String          @id @default(uuid())
  patientId       String          @unique
  patient         Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)

  pseudonym       String          @unique

  createdAt       DateTime        @default(now())

  @@index([pseudonym])
}

// ─── Modul 5: Patienten-Portal PWA ──────────────────────────

enum ConsentType {
  DATA_PROCESSING
  EMERGENCY_CONTACT
  MEDICATION_REMINDER
  PUSH_NOTIFICATIONS
  DATA_SHARING
}

enum MessageDirection {
  PATIENT_TO_PROVIDER
  PROVIDER_TO_PATIENT
  SYSTEM
}

enum DiaryMood {
  VERY_BAD
  BAD
  NEUTRAL
  GOOD
  VERY_GOOD
}

model PatientAccount {
  id              String            @id @default(uuid())
  patientId       String            @unique
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  email           String?           @unique
  phone           String?
  passwordHash    String
  pinHash         String?
  
  isActive        Boolean           @default(true)
  isVerified      Boolean           @default(false)
  verifiedAt      DateTime?
  lastLoginAt     DateTime?
  loginCount      Int               @default(0)
  
  locale          String            @default("de")
  notifyEmail     Boolean           @default(true)
  notifyPush      Boolean           @default(false)
  notifySms       Boolean           @default(false)
  
  devices         PatientDevice[]
  consents        PatientConsent[]
  diaryEntries    DiaryEntry[]
  measureTrackings MeasureTracking[]
  messages        ProviderMessage[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([email])
  @@index([phone])
}

model PatientDevice {
  id              String            @id @default(uuid())
  accountId       String
  account         PatientAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  deviceName      String
  deviceType      String            // ios, android, web
  pushToken       String?
  pushEndpoint    String?
  userAgent       String?
  
  isActive        Boolean           @default(true)
  lastSeenAt      DateTime          @default(now())
  
  createdAt       DateTime          @default(now())
  
  @@index([accountId])
  @@index([pushToken])
}

model PatientConsent {
  id              String            @id @default(uuid())
  accountId       String
  account         PatientAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  type            ConsentType
  granted         Boolean           @default(false)
  grantedAt       DateTime?
  revokedAt       DateTime?
  ipAddress       String?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@unique([accountId, type])
  @@index([accountId])
}

model DiaryEntry {
  id              String            @id @default(uuid())
  accountId       String
  account         PatientAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  patientId       String
  
  date            DateTime          @default(now())
  mood            DiaryMood?
  painLevel       Int?              // 0-10
  sleepQuality    Int?              // 0-10
  sleepHours      Float?
  symptoms        String[]
  notes           String?
  
  vitalBp         String?           // "120/80"
  vitalPulse      Int?
  vitalTemp       Float?
  vitalWeight     Float?
  vitalBloodSugar Float?
  
  offlineCreated  Boolean           @default(false)
  syncedAt        DateTime?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([accountId])
  @@index([patientId])
  @@index([date])
}

model MeasureTracking {
  id              String            @id @default(uuid())
  accountId       String
  account         PatientAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  measureId       String
  
  scheduledDate   DateTime
  completedDate   DateTime?
  skippedDate     DateTime?
  skippedReason   String?
  
  dose            String?
  notes           String?
  sideEffects     String[]
  
  offlineCreated  Boolean           @default(false)
  syncedAt        DateTime?
  
  createdAt       DateTime          @default(now())
  
  @@index([accountId])
  @@index([measureId])
  @@index([scheduledDate])
}

model ProviderMessage {
  id              String            @id @default(uuid())
  accountId       String
  account         PatientAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  patientId       String
  
  direction       MessageDirection
  subject         String?
  body            String
  
  senderName      String?
  senderRole      String?           // arzt, mfa, system
  
  isRead          Boolean           @default(false)
  readAt          DateTime?
  
  attachmentUrl   String?
  attachmentName  String?
  
  createdAt       DateTime          @default(now())
  
  @@index([accountId])
  @@index([patientId])
  @@index([isRead])
  @@index([createdAt])
}

// ─── Modul 6: Lokaler Modus / gematik / ePA ────────────────

enum DeploymentMode {
  CLOUD
  HYBRID
  LOCAL
}

enum TIConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
  MAINTENANCE
}

enum TICardType {
  SMC_B
  SMC_KT
  EGK
  HBA
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  RESTORING
}

enum EPADocumentType {
  ANAMNESE
  BEFUND
  ARZTBRIEF
  MEDIKATIONSPLAN
  LABORBERICHT
  BILDGEBUNG
  SONSTIGES
}

enum KIMMessageStatus {
  DRAFT
  SENDING
  SENT
  DELIVERED
  FAILED
  RECEIVED
  READ
}

model SystemConfig {
  id              String          @id @default(uuid())

  key             String          @unique
  value           String
  valueType       String          @default("string") // string, number, boolean, json
  category        String          // deployment, backup, network, ti, epa, kim, llm, security
  description     String?

  isSecret        Boolean         @default(false) // Wert verschlüsselt speichern
  isEditable      Boolean         @default(true)
  lastModifiedBy  String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([category])
  @@index([key])
  @@map("system_configs")
}

model BackupRecord {
  id              String          @id @default(uuid())

  filename        String
  filePath        String
  fileSize        Int             // Bytes
  checksum        String          // SHA-256
  encryptionKey   String?         // AES key identifier (not the key itself)

  status          BackupStatus    @default(PENDING)
  type            String          @default("full") // full, incremental, schema_only
  trigger         String          @default("manual") // manual, scheduled, pre_update

  dbVersion       String?
  appVersion      String?
  tablesIncluded  String[]
  recordCounts    Json?           // { "patients": 150, "sessions": 3200, ... }

  startedAt       DateTime        @default(now())
  completedAt     DateTime?
  duration        Int?            // Sekunden
  errorMessage    String?

  restoredAt      DateTime?
  restoredBy      String?

  createdAt       DateTime        @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("backup_records")
}

model TIConnection {
  id              String              @id @default(uuid())

  praxisId        String              @unique
  konnektorUrl    String
  konnektorVersion String?
  mandantId       String
  clientSystemId  String
  workplaceId     String

  // mTLS Zertifikate (Pfade, nicht Inhalte)
  clientCertPath  String?
  clientKeyPath   String?
  caCertPath      String?

  status          TIConnectionStatus  @default(DISCONNECTED)
  lastPingAt      DateTime?
  lastPingMs      Int?
  lastError       String?

  // Karten-Status
  smcbInserted    Boolean             @default(false)
  smcbExpiry      DateTime?
  smcbIccsn       String?             // Karten-ID
  hbaInserted     Boolean             @default(false)
  hbaExpiry       DateTime?

  // Feature-Flags
  epaEnabled      Boolean             @default(false)
  kimEnabled      Boolean             @default(false)
  vsdmEnabled     Boolean             @default(true)
  nfdmEnabled     Boolean             @default(false)

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  epaDocuments    EPADocument[]
  kimMessages     KIMMessage[]

  @@index([status])
  @@map("ti_connections")
}

model EPADocument {
  id              String          @id @default(uuid())
  connectionId    String
  connection      TIConnection    @relation(fields: [connectionId], references: [id])

  patientKvnr     String          // 10-stellige KVNR
  documentType    EPADocumentType
  title           String
  mimeType        String          @default("application/pdf")

  // FHIR Referenzen
  fhirDocumentId  String?         // DocumentReference.id in ePA
  fhirBundleId    String?
  loincCode       String?         // z.B. "34117-2" für Anamnese

  // Status
  uploadedToEpa   Boolean         @default(false)
  uploadedAt      DateTime?
  downloadedAt    DateTime?
  errorMessage    String?

  // Lokale Referenz
  localFilePath   String?
  fileSize        Int?
  checksum        String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([connectionId])
  @@index([patientKvnr])
  @@index([documentType])
  @@map("epa_documents")
}

model KIMMessage {
  id              String            @id @default(uuid())
  connectionId    String
  connection      TIConnection      @relation(fields: [connectionId], references: [id])

  // Absender/Empfänger (KIM-Adressen)
  fromAddress     String            // z.B. "praxis.mueller@kim.telematik"
  toAddresses     String[]          // Mehrere Empfänger möglich
  ccAddresses     String[]
  replyToAddress  String?

  subject         String
  body            String
  bodyHtml        String?

  // S/MIME
  isEncrypted     Boolean           @default(true)
  isSigned        Boolean           @default(true)
  smimeStatus     String?           // verified, invalid, unknown

  // Anhänge
  hasAttachments  Boolean           @default(false)
  attachmentCount Int               @default(0)
  attachmentPaths String[]

  // Status
  status          KIMMessageStatus  @default(DRAFT)
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  errorMessage    String?

  // VZD-Referenz
  recipientNames  String[]
  recipientOids   String[]          // Telematik-OIDs

  // Verknüpfung
  patientId       String?
  sessionId       String?
  messageId       String?           // SMTP Message-ID

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([connectionId])
  @@index([status])
  @@index([fromAddress])
  @@index([patientId])
  @@map("kim_messages")
}

// ═══════════════════════════════════════════════════════════════
// Modul 7: NFC-Praxis-Ökosystem & TreatmentFlows
// ═══════════════════════════════════════════════════════════════

enum NfcCheckpointType {
  ENTRANCE
  WAITING
  ROOM
  LAB
  EKG
  CHECKOUT
}

enum NfcScanStatus {
  ACCEPTED
  REJECTED
  REPLAY_BLOCKED
}

enum FlowStepType {
  WAITING
  REGISTRATION
  LAB
  EKG
  CONSULTATION
  CHECKOUT
  PAYMENT
}

enum FlowProgressStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum FeedbackEscalation {
  NONE
  REVIEW
  PRAXIS_LEITUNG
  EXTERNAL
}

model NfcCheckpoint {
  id           String             @id @default(uuid())
  locationId   String             @unique
  praxisId     String
  type         NfcCheckpointType
  roomName     String?
  coordinates  Json?
  nfcUid       String             @unique
  secretRef    String?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  scans        NfcScan[]

  @@index([praxisId, type])
  @@map("nfc_checkpoints")
}

model NfcScan {
  id            String         @id @default(uuid())
  checkpointId  String
  checkpoint    NfcCheckpoint  @relation(fields: [checkpointId], references: [id])
  sessionId     String?
  scannedAt     DateTime       @default(now())
  deviceInfo    String?
  ipHash        String?
  scanStatus    NfcScanStatus  @default(ACCEPTED)
  rejectReason  String?

  @@index([sessionId, scannedAt])
  @@index([checkpointId, scannedAt])
  @@map("nfc_scans")
}

model TreatmentFlow {
  id            String   @id @default(uuid())
  praxisId      String
  name          String
  description   String?
  serviceType   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  steps         FlowStep[]
  progressItems PatientFlowProgress[]

  @@index([praxisId, isActive])
  @@map("treatment_flows")
}

model FlowStep {
  id               String        @id @default(uuid())
  flowId           String
  flow             TreatmentFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  order            Int
  type             FlowStepType
  roomType         String?
  specificRoomId   String?
  estimatedMinutes Int           @default(15)
  bufferMinutes    Int           @default(5)
  requiredStaff    String[]
  instructions     Json
  preparationVideo String?
  nfcCheckpointId  String?
  condition        String?
  isSkippable      Boolean       @default(true)

  @@index([flowId, order])
  @@map("flow_steps")
}

model PatientFlowProgress {
  id                  String             @id @default(uuid())
  sessionId           String             @unique
  flowId              String
  flow                TreatmentFlow      @relation(fields: [flowId], references: [id])
  currentStep         Int                @default(0)
  status              FlowProgressStatus @default(ACTIVE)
  stepHistory         Json[]
  estimatedCompletion DateTime?
  actualCompletion    DateTime?
  delayMinutes        Int                @default(0)
  delayReason         String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
  @@map("patient_flow_progress")
}

model AnonymousFeedback {
  id               String              @id @default(uuid())
  praxisId         String
  sessionId        String?
  rating           Int
  text             String?
  categories       String[]
  containsThreats  Boolean             @default(false)
  threatKeywords   String[]
  escalationStatus FeedbackEscalation  @default(NONE)
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime            @default(now())

  @@index([praxisId, createdAt])
  @@index([containsThreats, escalationStatus])
  @@map("anonymous_feedback")
}

model PraxisChatMessage {
  id           String   @id @default(uuid())
  sessionId    String
  senderType   String
  senderId     String?
  contentType  String   @default("TEXT")
  content      String
  isTemplate   Boolean  @default(false)
  templateId   String?
  readAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([senderType, createdAt])
  @@map("praxis_chat_messages")
}

enum PaymentType {
  SELBSTZAHLER
  IGEL
  PRIVAT
  COPAYMENT
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

model PaymentTransaction {
  id               String        @id @default(uuid())
  sessionId        String
  patientId        String
  amount           Float
  currency         String        @default("EUR")
  type             PaymentType   @default(SELBSTZAHLER)
  status           PaymentStatus @default(PENDING)
  paymentProvider  String        @default("stripe")
  providerIntentId String?
  nfcCardToken     String?
  receiptUrl       String?
  description      String?
  metadata         Json?
  createdAt        DateTime      @default(now())
  completedAt      DateTime?
  refundedAt       DateTime?

  @@index([sessionId, status])
  @@index([patientId, createdAt])
  @@map("payment_transactions")
}

enum AvatarType {
  TWO_D     @map("2D")
  THREE_D   @map("3D")
  REAL_PHOTO
}

model StaffAvatar {
  id                 String     @id @default(uuid())
  staffId            String     @unique
  voiceCloneId       String?
  voiceSettings      Json?
  avatarUrl          String?
  avatarType         String     @default("2D")
  supportedLanguages String[]
  accentSettings     Json?
  consentSignedAt    DateTime?
  isActive           Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@map("staff_avatars")
}
