  @@index([priority, completed])
  @@map("staff_todos")
}

// ═══════════════════════════════════════════════════════════════
// DiggAI: Multi-Agenten-System
// ═══════════════════════════════════════════════════════════════

enum AgentType {
  ORCHESTRATOR
  EMPFANG
  ABRECHNUNG
  TRIAGE
  CUSTOM
}

enum AgentStatus {
  IDLE
  BUSY
  ERROR
  DISABLED
}

enum AgentTaskStatus {
  PENDING
  QUEUED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum AgentTaskPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

// ─── Agent Definition ────────────────────────────────────────

model Agent {
  id           String      @id @default(uuid())
  name         String      @unique
  type         AgentType
  description  String?
  systemPrompt String // Das Haupt-System-Prompt des Agenten
  version      Int         @default(1)
  status       AgentStatus @default(IDLE)
  enabled      Boolean     @default(true)

  // Konfiguration (Tools, Modell, etc.)
  config Json? // { model, temperature, maxTokens, tools: [] }

  // Metriken
  totalTasks    Int  @default(0)
  successTasks  Int  @default(0)
  failedTasks   Int  @default(0)
  avgDurationMs Int?

  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tasks     AgentTask[]
  auditLogs AgentAuditLog[]

  @@index([type, enabled])
  @@index([status])
  @@map("agents")
}

// ─── Agent Task (Job-Queue) ───────────────────────────────────

model AgentTask {
  id      String @id @default(uuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id])

  type     String // "book_appointment" | "triage_call" | "generate_invoice" etc.
  status   AgentTaskStatus   @default(PENDING)
  priority AgentTaskPriority @default(NORMAL)

  // Input/Output (keine PHI — nur anonymisierte IDs oder nicht-sensible Daten)
  inputData    Json? // Anonymisierter Task-Input
  outputData   Json? // Ergebnis
  errorMessage String?

  // Nachverfolgung
  queuedAt    DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?

  // Kontext (anonymisierte Referenzen)
  sessionRef  String? // Anonymisierte Session-ID (nicht FK!)
  patientRef  String? // Pseudonymisierte Patienten-Referenz (nicht FK!)
  requestedBy String? // ArztUser.id oder "system"

  // RabbitMQ Message-ID zur Deduplizierung
  messageId String? @unique

  retryCount Int @default(0)
  maxRetries Int @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AgentAuditLog[]

  @@index([agentId, status])
  @@index([status, priority])
  @@index([createdAt])
  @@index([requestedBy])
  @@map("agent_tasks")
}

// ─── Agent Audit Log (DSGVO-Pflicht: KI-Entscheidungsnachverfolgung) ──

model AgentAuditLog {
  id      String     @id @default(uuid())
  agentId String
  agent   Agent      @relation(fields: [agentId], references: [id])
  taskId  String?
  task    AgentTask? @relation(fields: [taskId], references: [id])

  // Was hat der Agent getan?
  action  String // "task_started" | "llm_called" | "decision_made" | "task_completed" | "error"
  details String? // Freitext-Beschreibung der Aktion

  // KI-spezifische Daten (KEIN PHI!)
  modelUsed  String? // "llama3", "mistral", etc.
  promptHash String? // SHA-256 des Prompts (nicht der Prompt selbst)
  tokensUsed Int?
  latencyMs  Int?

  // Entscheidungs-Kontext (anonymisiert)
  decisionType  String? // "appointment_booked" | "triage_escalated" | "invoice_generated"
  confidence    Float? // 0.0 - 1.0 (Modell-Konfidenz wenn verfügbar)
  humanReview   Boolean @default(false) // War menschliche Überprüfung nötig?
  humanReviewBy String? // userId

  ipHash    String? // SHA-256 der Request-IP
  createdAt DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([taskId])
  @@index([action, createdAt])
  @@index([decisionType])
  @@map("agent_audit_logs")
}

// ─── Service Usage Log (Leistungs-Tracking pro Aktion) ──────

model ServiceUsageLog {
  id        String  @id @default(uuid())
  tenantId  String
  sessionId String?
  patientId String?

  serviceType String // "ANAMNESE", "TRIAGE", "CHAT", "AI_SUMMARY", "PDF_EXPORT", "CSV_EXPORT", "PVS_EXPORT", "REZEPT", "AU", "UEBERWEISUNG"
  actionName  String // z.B. "Fragebogen ausgefüllt", "KI-Auswertung generiert"

  durationMs   Int? // Wie lange hat die Aktion gedauert
  manualTimeMs Int? // Geschätzte manuelle Dauer (ohne DiggAI)
  timeSavedMs  Int? // Berechnete Zeitersparnis

  costEstimate Float? // Geschätzte Kosten dieser Aktion
  metadata     Json? // Zusätzliche Infos

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([serviceType, createdAt])
  @@index([sessionId])
  @@map("service_usage_logs")
}

// ─── Daily Summary (Tagesend-Zusammenfassung + Rechnung) ────

model DailySummary {
  id       String   @id @default(uuid())
  tenantId String
  date     DateTime @db.Date

  totalSessions     Int @default(0)
  completedSessions Int @default(0)
  totalUsageActions Int @default(0)

  serviceBreakdown Json @default("{}") // { "ANAMNESE": 12, "TRIAGE": 3, ... }

  totalTimeSavedMin   Float @default(0)
  totalCostSaving     Float @default(0)
  estimatedManualCost Float @default(0)

  invoiceGenerated Boolean @default(false)
  invoiceData      Json? // Rechnungsdaten als JSON

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, date])
  @@index([tenantId, date])
  @@map("daily_summaries")
}

// ============================================
// Auth Extensions (Refresh Token Rotation)
// ============================================

enum UserType {
  ARZT
  PATIENT
}

model RefreshToken {
  id            String   @id @default(uuid())
  tokenFamily   String   @default(uuid()) // Gruppen-ID für Rotation
  tokenHash     String   @unique // SHA-256 des Tokens (niemals Klartext!)

  // User Referenz (polymorph - kann Arzt oder Patient sein)
  userId        String
  userType      UserType // ARZT | PATIENT

  // Optional: Link zu Gerät
  deviceId      String?
  device        PatientDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  // Zeitstempel
  issuedAt      DateTime @default(now())
  expiresAt     DateTime
  rotatedAt     DateTime? // Wann wurde rotiert

  // Revocation
  isRevoked     Boolean  @default(false)
  revokedAt     DateTime?
  revokedReason String?

  // Metadata
  ipHash        String?  // SHA-256 der IP (DSGVO-konform)
  userAgent     String?

  // Security: Token Reuse Detection
  reuseDetected Boolean  @default(false)
  reuseCount    Int      @default(0)

  @@index([userId, userType])
  @@index([tokenFamily])
  @@index([expiresAt])
  @@index([isRevoked, expiresAt])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════════════════════════
// 2FA / TOTP Authentication
// ═══════════════════════════════════════════════════════════════

model TwoFactorAuth {
  id          String   @id @default(uuid())
  userId      String
  userType    String   // 'ARZT' | 'PATIENT'
  
  secret          String   // Base32 encoded TOTP secret
  backupCodes     String[] // SHA-256 hashed backup codes
  usedBackupCodes String[] @default([]) // Track used backup codes
  
  isEnabled   Boolean  @default(false)
  enabledAt   DateTime?
  verifiedAt  DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, userType])
  @@index([userId])
  @@map("two_factor_auth")
}

// ═══════════════════════════════════════════════════════════════
// Passkey / WebAuthn Credentials
// ═══════════════════════════════════════════════════════════════

model PasskeyCredential {
  id                  String   @id @default(uuid())
  userId              String
  userType            String   // 'ARZT' | 'PATIENT'
  
  credentialID        Bytes
  credentialPublicKey Bytes
  counter             Int      @default(0)
  
  deviceName          String
  transports          String[] // AuthenticatorTransport[]
  
  createdAt           DateTime @default(now())
  lastUsedAt          DateTime @updatedAt
  
  @@index([userId])
  @@index([credentialID])
  @@map("passkey_credentials")
}
