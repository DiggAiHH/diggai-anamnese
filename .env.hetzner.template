# DiggAI Anamnese — HETZNER PRODUCTION Environment Template
# Copy this to .env.production on the Hetzner server, then fill in real values.
# SECURITY: Never commit this file. Never expose it publicly.
#
# scp anamnese-app/.env.hetzner.template diggai@SERVER_IP:/opt/diggai/anamnese-app/.env.production

# ─── Database (Supabase Frankfurt — keep existing) ────────────────────────────
# Use the same DATABASE_URL from your working .env.production
DATABASE_URL="postgresql://..."

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
BACKEND_PROFILE=monolith
LOG_LEVEL=info
APP_VERSION=3.0.0
RETENTION_DAYS=90

# ─── Security ─────────────────────────────────────────────────────────────────
# Copy from existing .env.production — DO NOT regenerate (would break existing sessions)
JWT_SECRET="COPY_FROM_EXISTING_ENV"
JWT_EXPIRES_IN="24h"
ENCRYPTION_KEY="COPY_FROM_EXISTING_ENV"
ARZT_PASSWORD="COPY_FROM_EXISTING_ENV"
BACKUP_ENCRYPTION_KEY="COPY_FROM_EXISTING_ENV"

# ─── URLs (update to diggai.de) ───────────────────────────────────────────────
# Frontend is on Vercel at diggai.de (or app.diggai.de)
FRONTEND_URL="https://diggai.de"
# Backend is on this Hetzner server at api.diggai.de
API_PUBLIC_URL="https://api.diggai.de/api"

# ─── Redis (Docker internal — no change needed) ───────────────────────────────
REDIS_URL="redis://redis:6379"
REDIS_PASSWORD=""

# ─── Push Notifications (copy from existing) ──────────────────────────────────
VAPID_PUBLIC_KEY="COPY_FROM_EXISTING_ENV"
VAPID_PRIVATE_KEY="COPY_FROM_EXISTING_ENV"

# ─── Feature Flags ────────────────────────────────────────────────────────────
NFC_ENABLED=false
PAYMENT_ENABLED=false
TELEMED_ENABLED=false
TI_ENABLED=false
EPA_ENABLED=false
KIM_ENABLED=false

# ─── Email (optional) ─────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── LLM (optional — rule-based fallback active if not set) ───────────────────
OPENAI_API_KEY=""

# ─── Stripe (disabled until ready) ───────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
VITE_STRIPE_PUBLISHABLE_KEY=""

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=""
BACKUP_DIR="./backups"

# ─── Docker Postgres password (used by docker-compose.yml) ───────────────────
# NOTE: docker-compose.yml uses ${POSTGRES_PASSWORD} — set this too
POSTGRES_PASSWORD="CHANGE_ME_strong_random_password"
