{
  "name": "DiggAI Anamnese Platform",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",

  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  "forwardPorts": [3001, 5173, 5432, 6379],
  "portsAttributes": {
    "3001": { "label": "API Server" },
    "5173": { "label": "Vite Dev Server" },
    "5432": { "label": "PostgreSQL" },
    "6379": { "label": "Redis" }
  },

  "postCreateCommand": "npm ci && npx prisma generate",
  "postStartCommand": "docker compose -f docker-compose.local.yml up -d && sleep 3 && npx prisma migrate dev --name init 2>/dev/null || true",

  "customizations": {
    "vscode": {
      "extensions": [
        "prisma.prisma",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "lokalise.i18n-ally",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker",
        "ms-playwright.playwright",
        "esbenp.prettier-vscode",
        "yoavbls.pretty-ts-errors",
        "usernamehw.errorlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.preferences.importModuleSpecifier": "relative"
      }
    }
  },

  "remoteEnv": {
    "NODE_ENV": "development"
  }
}
