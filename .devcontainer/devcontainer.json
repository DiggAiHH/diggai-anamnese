{
  "name": "DiggAI Anamnese Platform",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",

  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },

  "forwardPorts": [3001, 5173, 5432, 6379],
  "portsAttributes": {
    "3001": {
      "label": "API Server (Express)",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Frontend (Vite Dev Server)",
      "onAutoForward": "openBrowser"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    }
  },

  "secrets": {
    "JWT_SECRET": {
      "description": "JWT Secret – mindestens 32 Zeichen. Generiere mit: openssl rand -hex 32"
    },
    "ENCRYPTION_KEY": {
      "description": "AES-256 Key – genau 32 Zeichen. Generiere mit: openssl rand -hex 16"
    },
    "DATABASE_URL": {
      "description": "PostgreSQL Connection URL. Standard: postgresql://anamnese:anamnese@localhost:5432/anamnese_db"
    },
    "ARZT_PASSWORD": {
      "description": "Initial Arzt/Admin-Passwort für den Seed (min. 12 Zeichen)"
    }
  },

  "onCreateCommand": "cp .env.example .env 2>/dev/null || true",

  "postCreateCommand": "npm ci && npx prisma generate && echo '✅ Dependencies installiert'",

  "postStartCommand": "docker compose -f docker-compose.local.yml up -d && sleep 5 && npx prisma migrate dev --name init 2>/dev/null || true && echo '🚀 Stack läuft: Frontend http://localhost:5173 | API http://localhost:3001'",

  "waitFor": "postCreateCommand",

  "updateContentCommand": "npm ci",

  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "prisma.prisma",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "lokalise.i18n-ally",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker",
        "ms-playwright.playwright",
        "esbenp.prettier-vscode",
        "yoavbls.pretty-ts-errors",
        "usernamehw.errorlens",
        "christian-kohler.path-intellisense",
        "formulahendry.auto-rename-tag",
        "wayou.vscode-todo-highlight"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2,
        "typescript.preferences.importModuleSpecifier": "relative",
        "typescript.tsdk": "node_modules/typescript/lib",
        "editor.inlineSuggest.enabled": true,
        "github.copilot.enable": {
          "*": true,
          "plaintext": false,
          "markdown": true
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.watcherExclude": {
          "**/node_modules/**": true,
          "**/dist/**": true,
          "**/.git/**": true
        }
      }
    },
    "codespaces": {
      "openFiles": ["README.md"]
    }
  },

  "remoteEnv": {
    "NODE_ENV": "development",
    "VITE_API_URL": "http://localhost:3001/api",
    "FRONTEND_URL": "http://localhost:5173"
  }
}
