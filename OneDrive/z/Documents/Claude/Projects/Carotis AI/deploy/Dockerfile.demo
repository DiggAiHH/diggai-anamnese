# syntax=docker/dockerfile:1.7

FROM node:22-alpine AS frontend-build
WORKDIR /src/frontend
COPY code/frontend/package*.json ./
RUN npm ci
COPY code/frontend/ ./
RUN npm run build

FROM python:3.13-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DATABASE_URL=sqlite+aiosqlite:////data/carotis_demo.db \
    ONNX_MODEL_PATH=/data/models/mfsd_unet.onnx \
    CORS_ORIGINS=https://app.carotis.diggai.de

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    libglib2.0-0 \
    libgomp1 \
    libsm6 \
    libxext6 \
    libxrender1 \
    nginx-light \
    supervisor \
    && rm -rf /var/lib/apt/lists/*

COPY code/backend/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY code/backend/app /app/app
COPY --from=frontend-build /src/frontend/dist /usr/share/nginx/html

RUN mkdir -p /data /var/log/supervisor /run/nginx && \
    adduser --disabled-password --gecos "" carotis && \
    chown -R carotis:carotis /data /app /usr/share/nginx/html /var/log/nginx /var/lib/nginx /run/nginx

COPY deploy/nginx.demo.conf /etc/nginx/nginx.conf
COPY deploy/supervisord.demo.conf /etc/supervisor/conf.d/carotis-demo.conf

EXPOSE 8080
VOLUME ["/data"]

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/carotis-demo.conf"]
